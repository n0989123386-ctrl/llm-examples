import streamlit as st
import pandas as pd

st.set_page_config(page_title="裕隆專屬股市監控系統", layout="wide")

# 您的觀察清單
stock_list = ["0056", "00915", "00918", "00919", "00878", "00929", "2409", "2464", "00403A", "00981A", "00992A"]

st.title("📈 裕隆專屬股市起漲點監控系統 1.0")
st.write("系統已啟動，正在針對您的 12 檔標的進行金水元素協調監控...")

# 顯示觀察清單
st.subheader("目前監控標的")
st.write(", ".join(stock_list))

if st.button("刷新即時報價與分析"):
    with st.spinner("正在連線三竹股市資料庫，比對起漲訊號..."):
        # 這裡會是未來串接真實數據的地方
        data = {
            "標的": stock_list,
            "狀態": ["監控中" for _ in stock_list],
            "起漲訊號": ["等待中" for _ in stock_list]
        }
        df = pd.DataFrame(data)
        st.table(df)
        st.success("數據更新完畢，請留意量能變化。")

st.info("💡 提示：若要更換名單，請隨時編輯程式碼中的 stock_list 變數。")



